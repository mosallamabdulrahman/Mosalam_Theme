{
  "name": "mosalam-theme",
  "private": true,
  "version": "1.0.0",
  "description": "Build tooling for the Mosalam custom WordPress theme (all blocks + theme.js + Tailwind CSS from one node_modules).",
  "scripts": {
    "build:blocks": "wp-scripts build --webpack-copy-php --config webpack.config.js",
    "build:css": "tailwindcss -i ./assets/css/tailwind-input.css -o ./assets/css/tailwind.css --minify",
    "build": "npm run build:blocks && npm run build:css",
    "start": "wp-scripts start --webpack-copy-php --config webpack.config.js"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.13"
  },
  "dependencies": {
    "motion": "^12.23.24"
  }
}
