{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mosalam/contact-hero",
  "title": "Contact Hero",
  "category": "mosalam-blocks",
  "icon": "smiley",
  "description": "Contact Us page hero banner.",
  "textdomain": "mosalam",
  "editorScript": "file:./build/index.js",
  "render": "file:./render.php",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Begin the dialogue"
    },
    "title": {
      "type": "string",
      "default": "CONTACT US"
    },
    "description": {
      "type": "string",
      "default": "Connect with our team of elite architects and strategists. Whether you're navigating complex transformations or seeking precise technical guidance, we are ready to curate your next step."
    },
    "backgroundImage": {
      "type": "string",
      "default": "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=1920"
    },
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "supports": {
    "align": [
      "wide",
      "full"
    ]
  }
}
