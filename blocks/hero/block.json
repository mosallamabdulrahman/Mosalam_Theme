{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "mosalam/hero",
  "title": "Home Hero",
  "category": "mosalam-blocks",
  "icon": "smiley",
  "description": "Cinematic full-width homepage hero with background image and CTA.",
  "textdomain": "mosalam",
  "editorScript": "file:./build/index.js",
  "render": "file:./render.php",
  "attributes": {
    "eyebrow": {
      "type": "string",
      "default": "Empowering Progress"
    },
    "title": {
      "type": "string",
      "default": "Transforming the way we work"
    },
    "description": {
      "type": "string",
      "default": "We deliver the digital foundations that empower people and organisations to achieve their potential through sustainable technology innovation."
    },
    "ctaLabel": {
      "type": "string",
      "default": "Speak to a specialist"
    },
    "backgroundImage": {
      "type": "string",
      "default": "abstract-high-tech-digital-background.webp"
    },
    "scrollLabel": {
      "type": "string",
      "default": "Scroll Narrative"
    },
    "align": {
      "type": "string",
      "default": "full"
    }
  },
  "supports": {
    "align": ["wide", "full"]
  }
}
